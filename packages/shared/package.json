    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^2.0.0"
  }
}
